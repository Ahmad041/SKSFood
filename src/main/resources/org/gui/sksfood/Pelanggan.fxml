                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="10.0" style="-fx-background-color: #F8F9FC; -fx-border-color: #E4E8F2; -fx-border-radius: 10; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                                 <padding>
                                    <Insets bottom="16.0" left="18.0" right="18.0" top="14.0" />
                                 </padding>
                                 <children>
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #888;" text="TOTAL PELANGGAN" />
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                       <children>
                                          <Label fx:id="lblTotalPelanggan" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="0" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label style="-fx-font-size: 20px; -fx-text-fill: #1A3A8F;" text="👥" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              <VBox spacing="10.0" style="-fx-background-color: #F8F9FC; -fx-border-color: #E4E8F2; -fx-border-radius: 10; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                                 <padding>
                                    <Insets bottom="16.0" left="18.0" right="18.0" top="14.0" />
                                 </padding>
                                 <children>
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #888;" text="PELANGGAN AKTIF" />
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                       <children>
                                          <Label fx:id="lblPelangganAktif" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="0" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label style="-fx-font-size: 20px; -fx-text-fill: #2FA84F;" text="👤" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              <VBox spacing="10.0" style="-fx-background-color: #F8F9FC; -fx-border-color: #E4E8F2; -fx-border-radius: 10; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                                 <padding>
                                    <Insets bottom="16.0" left="18.0" right="18.0" top="14.0" />
                                 </padding>
                                 <children>
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #888;" text="PELANGGAN NON AKTIF" />
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                       <children>
                                          <Label fx:id="lblPelangganNonAktif" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #1A2340;" text="0" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label style="-fx-font-size: 20px; -fx-text-fill: #D63030;" text="👥" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                              <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Form Input Pelanggan" />
                           </children>
                        </HBox>
                        <!-- Kolom Password sudah dihapus total dari form ini. -->
                        <GridPane hgap="30.0" vgap="14.0">
                           <columnConstraints>
                              <ColumnConstraints hgrow="NEVER" minWidth="130.0" prefWidth="130.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                              <ColumnConstraints hgrow="NEVER" minWidth="130.0" prefWidth="130.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="34.0" prefHeight="34.0" vgrow="SOMETIMES" />
                           </rowConstraints>
                           <children>
                              <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="ID Pelanggan" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                              <TextField fx:id="txtIdPelanggan" editable="false" maxWidth="1.7976931348623157E308" promptText="Auto-generate" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                              <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                 <children>
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Nama Pelanggan" />
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #D63030;" text="*" />
                                 </children>
                              </HBox>
                              <TextField fx:id="txtNamaPelanggan" maxWidth="1.7976931348623157E308" promptText="Masukkan nama pelanggan (huruf saja)" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                              <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                 <children>
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="No. Telepon" />
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #D63030;" text="*" />
                                 </children>
                              </HBox>
                              <TextField fx:id="txtNoTelp" maxWidth="1.7976931348623157E308" promptText="08xxxxxxxxxx" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                              <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                 <children>
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Email" />
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #D63030;" text="*" />
                                 </children>
                              </HBox>
                              <TextField fx:id="txtEmail" maxWidth="1.7976931348623157E308" promptText="nama@gmail.com / yahoo.com / outlook.com / dll" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                              <HBox alignment="CENTER_LEFT" spacing="2.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                 <children>
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Departemen" />
                                    <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #D63030;" text="*" />
                                 </children>
                              </HBox>
                              <ComboBox fx:id="cmbDepartemen" maxWidth="1.7976931348623157E308" promptText="Pilih Departemen" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                              <Label fx:id="lblStatusAkun" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #333;" text="Status Akun" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                              <ComboBox fx:id="cmbStatusAkun" maxWidth="1.7976931348623157E308" promptText="Pilih status" style="-fx-background-color: #F8F9FC; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                           </children>
                        </GridPane>
                     </children>
                  </VBox>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <HBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Button fx:id="btnSimpan" onAction="#onSimpan" prefHeight="38" prefWidth="120" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="SIMPAN" />
                              <Button fx:id="btnUbah" onAction="#onUbah" prefHeight="38" prefWidth="110" style="-fx-background-color: #E8A020; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="UBAH" />
                              <Button fx:id="btnHapus" onAction="#onHapus" prefHeight="38" prefWidth="130" style="-fx-background-color: #D63030; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="HAPUS" />
                              <Button fx:id="btnBatal" onAction="#onBersih" prefHeight="38" prefWidth="110" style="-fx-background-color: #A0A8B8; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="BATAL" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <ComboBox fx:id="cmbFilterStatus" prefHeight="38" prefWidth="130" promptText="Status" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;" />
                              <ComboBox fx:id="cmbFilterDepartemen" prefHeight="38" prefWidth="140" promptText="Departemen" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;" />
                              <ComboBox fx:id="cmbUrutkan" prefHeight="38" prefWidth="170" promptText="Urutkan" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px;" />
                              <TextField fx:id="txtCari" prefHeight="38" prefWidth="220" promptText="Cari ID / Nama / No. Telepon" style="-fx-background-color: WHITE; -fx-border-color: #D0D8E8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 14; -fx-font-size: 13px;" />
                              <Button fx:id="btnCari" onAction="#onCari" prefHeight="38" prefWidth="94" style="-fx-background-color: #1A3A8F; -fx-text-fill: WHITE; -fx-font-size: 13px; -fx-font-weight: 700; -fx-background-radius: 6; -fx-cursor: hand;" text="CARI" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
                  <VBox spacing="16.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,2);">
                     <padding>
                        <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Rectangle arcHeight="4" arcWidth="4" fill="#1A3A8F" height="20" width="4" />
                              <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #1A3A8F;" text="Daftar Pelanggan" />
                           </children>
                        </HBox>
                        <TableView fx:id="tabelPelanggan" onMouseClicked="#onTableClick" prefHeight="320" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colId" prefWidth="110" text="ID Pelanggan" />
                              <TableColumn fx:id="colNama" prefWidth="200" text="Nama Pelanggan" />
                              <TableColumn fx:id="colNoTelp" prefWidth="150" text="No. Telepon" />
                              <TableColumn fx:id="colEmail" prefWidth="180" text="Email" />
                              <TableColumn fx:id="colDepartemen" prefWidth="140" text="Departemen" />
                              <TableColumn fx:id="colStatusAkun" prefWidth="140" text="Status Akun" />
                           </columns>
                           <placeholder>
                              <Label style="-fx-font-size: 13px; -fx-text-fill: #AAA;" text="Tidak ada data pelanggan." />
                           </placeholder>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Label fx:id="lblTotal" style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: 600;" text="Total Data : 0" HBox.hgrow="ALWAYS" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button onAction="#onFirstPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="«" />
                              <Button onAction="#onPrevPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="‹" />
                              <Label fx:id="lblPage" prefHeight="28" prefWidth="34" style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: WHITE; -fx-background-color: #1A3A8F; -fx-background-radius: 5; -fx-alignment: CENTER;" text="1" />
                              <Button onAction="#onNextPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="›" />
                              <Button onAction="#onLastPage" prefHeight="28" prefWidth="34" style="-fx-background-color: #F0F4FF; -fx-text-fill: #1A3A8F; -fx-font-weight: 700; -fx-background-radius: 5; -fx-cursor: hand;" text="»" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
